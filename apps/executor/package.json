    "@turnkey/http": "^4.0.0",
    "@turnkey/sdk-server": "^6.0.0",
    "@turnkey/viem": "^0.14.29",
    "viem": "^2.50.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260601.0",
    "@types/node": "^24.12.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
