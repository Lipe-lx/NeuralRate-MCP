{
  "name": "executor",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "presync-env": "node ../../scripts/sync-runtime-envs.mjs",
    "predev": "npm run presync-env",
    "prebuild": "npm run presync-env",
    "prestart": "npm run presync-env",
    "dev": "tsx watch src/index.ts",
    "dev:worker": "wrangler dev",
    "build": "tsc -p tsconfig.json",
