{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "presync-docs": "node ../../scripts/sync-public-docs.mjs",
    "presync-env": "node ../../scripts/sync-web-public-env.mjs",
    "prebuild": "npm run presync-docs && npm run presync-env",
    "build": "tsc -b && vite build",
    "test": "node --import tsx --test src/lib/userState.test.ts src/lib/auth.test.ts",
    "test:ui": "vitest run",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@biconomy/abstractjs": "^1.1.6",
    "@privy-io/react-auth": "^3.27.1",
    "@safe-global/protocol-kit": "^7.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "viem": "^2.39.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^3.0.5"
  }
}
